// Testbench for the Connect 4 game. Drives reset, the slow tick, and the
// button pulses straight into the game_controller. Scenario: P1 keeps
// dropping in column 3 and P2 in column 4, so P1 should get a vertical
// four-in-a-row and win (winner = 0).
module connect4_testbench;
    logic clk, reset, tick;
    logic ev_left, ev_right, ev_drop;
    logic [5:0][6:0][1:0] board;
    logic [2:0] cursor_col;
    logic       current_player;
    logic       game_won, game_draw, winner;
    logic       falling_active;
    logic [2:0] falling_row, falling_col;
    logic       falling_player;

    game_controller dut (
        .clk, .reset, .tick,
        .ev_left, .ev_right, .ev_drop,
        .board, .cursor_col, .current_player,
        .game_won, .game_draw, .winner,
        .falling_active, .falling_row, .falling_col, .falling_player
    );

    // Elaborate the renderer too, so simulation covers every module.
    logic [15:0][15:0] RedPixels, GrnPixels;
    board_renderer render (
        .board, .cursor_col, .current_player,
        .show_cursor(~game_won & ~game_draw),
        .falling_active, .falling_row, .falling_col, .falling_player,
        .RedPixels, .GrnPixels
    );

    parameter PERIOD = 10;
    initial begin
        clk = 0;
        forever #(PERIOD/2) clk = ~clk;
    end

    // The sequence of columns to play.  Player 1 takes the even-indexed
    // entries (col 3) and Player 2 the odd ones (col 4).  After seven moves
    // Player 1 has four pieces stacked in column 3 and should win.
    logic [6:0][2:0] play_col;
    integer move_idx, step;

    initial begin
        play_col[0] = 3'd3;
        play_col[1] = 3'd4;
        play_col[2] = 3'd3;
        play_col[3] = 3'd4;
        play_col[4] = 3'd3;
        play_col[5] = 3'd4;
        play_col[6] = 3'd3;

        ev_left = 1'b0; ev_right = 1'b0; ev_drop = 1'b0; tick = 1'b0;
        reset = 1'b1; @(posedge clk); @(posedge clk);
        reset = 1'b0; @(posedge clk);

        for (move_idx = 0; move_idx < 7; move_idx = move_idx + 1) begin
            // Step the cursor toward play_col[move_idx].  Six steps are
            // plenty because cursor and target are both in 0..6.
            for (step = 0; step < 6; step = step + 1) begin
                if (cursor_col < play_col[move_idx]) begin
                    ev_right = 1'b1; tick = 1'b1; @(posedge clk);
                    ev_right = 1'b0; tick = 1'b0; @(posedge clk);
                end else if (cursor_col > play_col[move_idx]) begin
                    ev_left = 1'b1; tick = 1'b1; @(posedge clk);
                    ev_left = 1'b0; tick = 1'b0; @(posedge clk);
                end else begin
                    @(posedge clk);
                end
            end
            // Press drop.
            ev_drop = 1'b1; tick = 1'b1; @(posedge clk);
            ev_drop = 1'b0; tick = 1'b0; @(posedge clk);
            // Tick the animation until the piece has settled and the
            // controller has returned to a turn / win / draw state.  20
            // ticks is more than enough to walk a piece from row 5 to row 0
            // and run the win check.
            for (step = 0; step < 20; step = step + 1) begin
                tick = 1'b1; @(posedge clk);
                tick = 1'b0; @(posedge clk);
            end
            $display("%0t move=%0d col=%0d won=%b draw=%b winner=%b",
                     $time, move_idx, play_col[move_idx],
                     game_won, game_draw, winner);
        end

        // After seven moves Player 1 (winner=0) should have a vertical win.
        $display("FINAL: game_won=%b game_draw=%b winner=%b",
                 game_won, game_draw, winner);

        // Verify reset clears the board and re-arms the game.
        reset = 1'b1; @(posedge clk); @(posedge clk);
        reset = 1'b0; @(posedge clk); @(posedge clk);
        $display("AFTER RESET: game_won=%b cursor_col=%0d board[0][3]=%b",
                 game_won, cursor_col, board[0][3]);

        $stop;
    end
endmodule
